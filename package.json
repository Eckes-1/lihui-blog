{
  "name": "lihui-blog",
  "type": "module",
  "version": "26.5.6",
  "scripts": {
    "dev": "astro dev",
    "dev:server": "nodemon server/index.js",
    "dev:admin": "cd admin && npx vite",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev:admin\"",
    "build": "astro build",
    "build:admin": "cd admin && npx vite build",
    "build:cf": "pnpm build:admin && mkdir -p public/admin && cp -r admin/dist/* public/admin/ && pnpm build && rm -rf public/admin && rm -rf dist/admin && cp -r admin/dist dist/admin && node -e \"const f='dist/_routes.json';const r=JSON.parse(require('fs').readFileSync(f,'utf8'));r.exclude=r.exclude.filter(e=>!e.startsWith('/admin'));r.exclude.push('/admin/*');require('fs').writeFileSync(f,JSON.stringify(r,null,2))\"",
    "preview": "astro preview",
    "start": "NODE_ENV=production node server/index.js",
    "astro": "astro",
    "newpost": "node script/newpost.js",
    "cf:dev": "wrangler pages dev --compatibility-flags=nodejs_compat --d1=DB -- pnpm dev",
    "cf:deploy": "pnpm build:cf && wrangler pages deploy dist"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^12.5.3",
    "@astrojs/node": "^9.5.5",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/svelte": "^7.2.4",
    "@chinese-fonts/lxgwwenkaibright": "^2.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@iconify/svelte": "^5.2.1",
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "@tailwindcss/vite": "^4.1.13",
    "aos": "^2.3.4",
    "astro": "^5.13.7",
    "astro-icon": "^1.1.5",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dompurify": "^3.4.2",
    "express": "^5.2.1",
    "hastscript": "^9.0.1",
    "hono": "^4.7.11",
    "http-proxy-middleware": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.22",
    "marked": "^18.0.2",
    "mdast-util-to-string": "^4.0.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.7",
    "pagefind": "^1.4.0",
    "photoswipe": "^5.4.4",
    "reading-time": "^1.5.0",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.3",
    "svelte": "^5.46.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/fluent": "^1.2.45",
    "@iconify-json/material-symbols": "^1.2.35",
    "@iconify-json/simple-icons": "^1.2.48",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "wrangler": "^4.18.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ]
  }
}
