---
import '@styles/global.css'
import { getDynamicSiteConfig, getDynamicLicenseConfig } from '@utils/dynamic-config'
import MainPageLayout from '@layouts/MainPageLayout.astro'
import Markdown from '@components/misc/Markdown.astro'
import ImageModule from '@components/misc/ImageModule.astro'
import FabMenu from '@components/control/FabMenu.astro'
import TOC from '@components/TOC.svelte'
import LicenseCard from '@components/misc/LicenseCard.astro'
import Comments from '@components/comment/Comments.svelte'
import Twikoo from '@components/comment/thirdparty/twikoo.astro'
import BlogNavi from '@components/control/BlogNavi.astro'

import { getPostBySlug, getPosts } from '@utils/api'
import { i18n } from "astro:config/client";
import i18nit from '@i18n/translation'

import { formatFullDate } from '@/utils/time'
import { getRelativeLocaleUrl } from '@utils/url-utils';
import { renderMarkdown, extractHeadings, calculateReadingTime } from '@utils/markdown'

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

const db = Astro.locals.runtime?.env?.DB || (globalThis as any).__D1_DB || null;

const slugParam = Astro.params.id;
if (!slugParam) {
  return Astro.redirect('/404');
}

let post: any = null;
try {
  post = await getPostBySlug(slugParam, db);
} catch (e) {
  console.error('[BlogPage] Failed to get post:', e);
}
if (!post) {
  return Astro.redirect('/404');
}

let siteConfig: any;
let licenseConfig: any;
try {
  siteConfig = await getDynamicSiteConfig(db);
  licenseConfig = await getDynamicLicenseConfig(db);
} catch (e) {
  console.error('[BlogPage] Failed to get config:', e);
  siteConfig = { title: 'LiHui', blogNavi: { enable: false }, comments: { enable: false }, toc: { enable: false } };
  licenseConfig = { enable: false };
}

const renderedHtml = await renderMarkdown(post.content || '');
const headings = extractHeadings(renderedHtml);
const { words, minutes } = calculateReadingTime(post.content || '');

const pageTitle = post.title + ' - ' + siteConfig.title;
const image = post.image || '';

let prevPost = null
let nextPost = null
try {
  if (db) {
    const currentPost = await db.prepare('SELECT id, title, slug_id, pin_top, pub_date FROM posts WHERE slug_id = ?').bind(slugParam).first()
    if (currentPost) {
      prevPost = await db.prepare(
        "SELECT id, title, slug_id FROM posts WHERE draft = 0 AND (pin_top < ? OR (pin_top = ? AND pub_date < ?) OR (pin_top = ? AND pub_date = ? AND id > ?)) ORDER BY pin_top DESC, pub_date DESC, id ASC LIMIT 1"
      ).bind(currentPost.pin_top || 0, currentPost.pin_top || 0, currentPost.pub_date, currentPost.pin_top || 0, currentPost.pub_date, currentPost.id).first()
      nextPost = await db.prepare(
        "SELECT id, title, slug_id FROM posts WHERE draft = 0 AND (pin_top > ? OR (pin_top = ? AND pub_date > ?) OR (pin_top = ? AND pub_date = ? AND id < ?)) ORDER BY pin_top ASC, pub_date ASC, id DESC LIMIT 1"
      ).bind(currentPost.pin_top || 0, currentPost.pin_top || 0, currentPost.pub_date, currentPost.pin_top || 0, currentPost.pub_date, currentPost.id).first()
    }
  }
} catch (e) {
}

const prev = prevPost ? {
  id: String(prevPost.slug_id || prevPost.id),
  data: { title: prevPost.title }
} : null;

const next = nextPost ? {
  id: String(nextPost.slug_id || nextPost.id),
  data: { title: nextPost.title }
} : null;
---
<MainPageLayout title={pageTitle} lang={currentLang} description={post.description}>
    <div class="mx-auto w-full max-w-[var(--page-width)] py-8 md:mt-0 mt-18">
        <div class="mb-18 text-center">
            <h1 class="font-bold text-3xl mb-2 pt-10 text-[var(--text-color)]">{ post.title }</h1>
            <p class="flex flex-wrap items-center justify-center font-bold text-[var(--text-color-70)] mt-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 448 512" class="mr-2"><path fill="currentColor" d="M128 0c17.7 0 32 14.3 32 32v32h128V32c0-17.7 14.3-32 32-32s32 14.3 32 32v32h48c26.5 0 48 21.5 48 48v48H0v-48c0-26.5 21.5-48 48-48h48V32c0-17.7 14.3-32 32-32M0 192h448v272c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48zm64 80v32c0 8.8 7.2 16 16 16h32c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16H80c-8.8 0-16 7.2-16 16m128 0v32c0 8.8 7.2 16 16 16h32c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16h-32c-8.8 0-16 7.2-16 16m144-16c-8.8 0-16 7.2-16 16v32c0 8.8 7.2 16 16 16h32c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16zM64 400v32c0 8.8 7.2 16 16 16h32c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16H80c-8.8 0-16 7.2-16 16m144-16c-8.8 0-16 7.2-16 16v32c0 8.8 7.2 16 16 16h32c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16zm112 16v32c0 8.8 7.2 16 16 16h32c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16h-32c-8.8 0-16 7.2-16 16"/></svg>
                <span> { formatFullDate(post.pub_date, currentLang) }</span>
            </p>
            <div class="flex justify-center">
                <div class="flex flex-wrap items-center justify-center text-sm text-[var(--text-color-70)] mt-2 gap-2">
                    <p class="flex items-center whitespace-nowrap mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 512 512" class="mr-1"><path fill="currentColor" d="m368.4 18.3l-55.7 55.8l125.2 125.2l55.7-55.7c21.9-21.9 21.9-57.3 0-79.2l-46-46.1c-21.9-21.9-57.3-21.9-79.2 0M288 94.6l-9.2 2.8l-144.1 43.2c-19.9 6-35.7 21.2-42.3 41L3.8 445.8c-3.8 11.3-1 23.9 7.3 32.4l153.6-153.5c-3-6.3-4.7-13.3-4.7-20.7c0-26.5 21.5-48 48-48s48 21.5 48 48s-21.5 48-48 48c-7.4 0-14.4-1.7-20.7-4.7L33.7 500.9c8.6 8.3 21.1 11.2 32.4 7.3l264.3-88.6c19.7-6.6 35-22.4 41-42.3l43.2-144.1l2.7-9.2z"/></svg>
                        <span class="py-1 px-1">{words} {t("pagecard.words")}</span>
                    </p>
                    <p class="flex items-center whitespace-nowrap mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 512 512" class="mr-1"><path fill="currentColor" d="M256 0a256 256 0 1 1 0 512a256 256 0 1 1 0-512m-24 120v136c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2V120c0-13.3-10.7-24-24-24s-24 10.7-24 24"/></svg>
                        <span class="py-1 px-1">{minutes} {t("pagecard.minutes")}</span>
                    </p>
                    <p class="flex items-center whitespace-nowrap mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 448 512" class="mr-1"><path fill="currentColor" d="M181.3 32.4c17.4 2.9 29.2 19.4 26.3 36.8l-9.8 58.8h95.1l11.5-69.3c2.9-17.4 19.4-29.2 36.8-26.3s29.2 19.4 26.3 36.8l-9.7 58.8H416c17.7 0 32 14.3 32 32s-14.3 32-32 32h-68.9l-21.3 128H384c17.7 0 32 14.3 32 32s-14.3 32-32 32h-68.9l-11.5 69.3c-2.9 17.4-19.4 29.2-36.8 26.3s-29.2-19.4-26.3-36.8l9.8-58.7h-95.1l-11.5 69.3c-2.9 17.4-19.4 29.2-36.8 26.3s-29.2-19.4-26.3-36.8l9.6-58.9H32c-17.7 0-32-14.3-32-32s14.3-32 32-32h68.9l21.3-128H64c-17.7 0-32-14.3-32-32s14.3-32 32-32h68.9l11.5-69.3c2.9-17.4 19.4-29.2 36.8-26.3zm5.8 159.6l-21.3 128h95.1l21.3-128z"/></svg>
                        <a href={getRelativeLocaleUrl(currentLang, `/archives/?category=${post.category}`)} class="category-tag">{post.category || t("pagecard.uncategorized")}</a>
                    </p>
                </div>
            </div>
        </div>
        {image && (
            <div class="cover overflow-hidden">
                <ImageModule src={image} class="w-full h-full object-cover"/>
            </div>
        )}
        {post.draft === 1 && (
        <div class="my-8 flex items-start gap-3 rounded-lg border border-[var(--danger-border-color)] bg-[var(--danger-bg-color)] p-4 text-sm text-[var(--danger-text-color)] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 512 512" class="mt-0.5 shrink-0 opacity-80"><path fill="currentColor" d="M256 32c14.2 0 27.3 7.5 34.5 19.8l216 368c7.3 12.4 7.3 27.7.2 40.1S486.3 480 472 480H40c-14.3 0-27.6-7.7-34.7-20.1s-7-27.8.2-40.1l216-368C228.7 39.5 241.8 32 256 32m0 128c-13.3 0-24 10.7-24 24v112c0 13.3 10.7 24 24 24s24-10.7 24-24V184c0-13.3-10.7-24-24-24m32 224a32 32 0 1 0-64 0a32 32 0 1 0 64 0"/></svg>
            <div>
                <p class="leading-relaxed">
                    <span class="font-semibold">{t("draftNote.warning")}</span>
                    {t("draftNote.description")}
                </p>
            </div>
        </div>
        )}
        <Markdown class="mb-6 mt-10 markdown-content onload-animation">
            <Fragment set:html={renderedHtml} />
        </Markdown>
        {licenseConfig.enable &&
        <LicenseCard title={post.title} pubDate={post.pub_date}/>
        }
        {
            siteConfig.blogNavi.enable &&
            <BlogNavi prev={prev} next={next}/>
        }
        {
            (siteConfig.comments.enable && siteConfig.comments.platform === "default") &&
            <Comments postSlug={post.slug_id} language={currentLang} postTitle={post.title} client:visible/>
        }
        {
            (siteConfig.comments.enable && siteConfig.comments.platform === "twikoo") &&
            <Twikoo postSlug={post.slug_id} language={currentLang} envId={siteConfig.comments.backendUrl}/>
        }
    </div>
    {
        siteConfig.toc.enable &&
        <TOC headings={headings} language={currentLang} client:load/>
    }
    <FabMenu headings={headings} showComment={siteConfig.comments.enable} showBackBottom={!siteConfig.comments.enable}/>
</MainPageLayout>
