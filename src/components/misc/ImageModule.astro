---
interface Props {
    src: string;
    alt?: string;
    id?: string;
    class?: string;
    width?: number;
    height?: number;
}

const { src, alt, id, width, height } = Astro.props;
const className = Astro.props.class;

const isLocal = !(
    src.startsWith("/") ||
    src.startsWith("http")
);
---
<div
  class:list={["image-wrapper", className]}
  data-lqip-enabled="false"
>
    {isLocal ? (
        <img
            src={src}
            alt={alt || ""}
            id={id}
            width={width}
            height={height}
            loading="lazy"
            data-loaded="true"
        />
    ) : (
        <img
            src={src}
            alt={alt || ""}
            id={id}
            width={width}
            height={height}
            loading="lazy"
            data-loaded="true"
        />
    )}
</div>

<style>
.image-wrapper {
    position: relative;
    overflow: hidden;
    background-color: transparent;
    display: block;
}

.image-wrapper img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 1;
}
</style>
